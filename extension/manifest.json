{
  "manifest_version": 3,
  "name": "Browser Ext MCP",
  "version": "0.1.0",
  "description": "Side panel browser control extension for a local MCP bridge.",
  "homepage_url": "https://github.com/HERRKIN/browser-ext-mcp",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "alarms",
    "debugger",
    "offscreen",
    "scripting",
    "storage",
    "sidePanel",
    "tabGroups",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Browser Ext MCP"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
